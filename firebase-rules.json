{
  "rules": {
    "users": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId"
      }
    },
    "images": {
      "$roomId": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('creatorId').val() === auth.uid || (data.child('createdAt').exists() && data.child('createdAt').val() < now - 86400000))",
        ".indexOn": ["createdAt", "status"],
        "creatorId": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        },
        "status": {
          ".validate": "newData.isString() && ['waiting', 'playing', 'finished'].indexOf(newData.val()) !== -1"
        },
        "currentRound": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "gameState": {
          ".write": "auth != null && (root.child('rooms').child($roomId).child('creatorId').val() === auth.uid || (root.child('rooms').child($roomId).child('createdAt').exists() && root.child('rooms').child($roomId).child('createdAt').val() < now - 86400000))",
          ".validate": "newData.isObject()",
          "round": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "status": {
            ".validate": "newData.isString() && ['waiting', 'playing', 'meeting', 'voting', 'finished'].indexOf(newData.val()) !== -1"
          },
          "timeRemaining": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        },
        "players": {
          "$playerName": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['name', 'role', 'status'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
            },
            "role": {
              ".validate": "newData.isString() && ['crewmate', 'impostor', 'scientist'].indexOf(newData.val()) !== -1"
            },
            "status": {
              ".validate": "newData.isString() && ['alive', 'dead', 'ghost'].indexOf(newData.val()) !== -1"
            },
            "joinedAt": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },
            "lastSeen": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },
            "tasks": {
              "$taskId": {
                ".write": "auth != null",
                "completed": {
                  ".validate": "newData.isBoolean()"
                },
                "completedAt": {
                  ".validate": "newData.isNumber() && newData.val() <= now"
                }
              }
            },
            "kills": {
              "$killId": {
                ".write": "auth != null",
                "targetId": {
                  ".validate": "newData.isString()"
                },
                "timestamp": {
                  ".validate": "newData.isNumber() && newData.val() <= now"
                }
              }
            }
          }
        },
        "votes": {
          ".read": "auth != null",
          "$playerName": {
            ".write": "auth != null"
          }
        },
        "config": {
          ".read": "auth != null",
          ".write": "auth != null && (root.child('rooms').child($roomId).child('creatorId').val() === auth.uid || (root.child('rooms').child($roomId).child('createdAt').exists() && root.child('rooms').child($roomId).child('createdAt').val() < now - 86400000))",
          "roundTimes": {
            ".validate": "newData.isArray()"
          },
          "discussionTime": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "votingTime": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          }
        }
      }
    },
    "rateLimit": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        ".validate": "newData.isObject()",
        "lastRoomCreation": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "publicMetadata": {
      ".read": true,
      ".write": false,
      "version": {
        ".validate": "newData.isString()"
      },
      "maintenance": {
        ".validate": "newData.isBoolean()"
      }
    },
    ".read": false,
    ".write": false
  }
}
